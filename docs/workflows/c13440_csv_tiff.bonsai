<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:p1="clr-namespace:AllenNeuralDynamics.HamamatsuCamera;assembly=AllenNeuralDynamics.HamamatsuCamera"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:C13440">
          <p1:Regions />
          <p1:CropMode>Auto</p1:CropMode>
          <p1:EnableBundling>false</p1:EnableBundling>
          <p1:BundleSize>1</p1:BundleSize>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:Processing">
          <p1:DeinterleaveCount>1</p1:DeinterleaveCount>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:CsvWriter">
          <p1:Suffix>Timestamp</p1:Suffix>
          <p1:Overwrite>false</p1:Overwrite>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="p1:TiffWriter">
          <p1:Suffix>Timestamp</p1:Suffix>
          <p1:FramesPerTiff>1000</p1:FramesPerTiff>
        </Combinator>
      </Expression>
    </Nodes>
    <Edges>
      <Edge From="0" To="1" Label="Source1" />
      <Edge From="1" To="2" Label="Source1" />
      <Edge From="1" To="3" Label="Source1" />
    </Edges>
  </Workflow>
</WorkflowBuilder>